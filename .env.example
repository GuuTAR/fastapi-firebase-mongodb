APP_NAME=fastapi-firebase-mongodb
DEBUG=true

MONGODB_URI=
MONGODB_DB=

# ── Firebase service-account fields ───────────────────────────────────────────
# Copy each value from the JSON downloaded via:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# FIREBASE_PRIVATE_KEY: paste the private key on one line; literal \n sequences
# are converted to real newlines automatically by the server.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Web API key from the Firebase project settings (Project settings > General).
# Required for POST /api/v1/auth/token (email/password sign-in).
FIREBASE_WEB_API_KEY=
